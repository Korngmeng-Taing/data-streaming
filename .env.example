# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9093
KAFKA_TOPIC=crypto-prices

# Crypto API (CoinGecko free tier)
CRYPTO_API_BASE_URL=https://api.coingecko.com/api/v3
CRYPTO_IDS=bitcoin,ethereum,solana,cardano,polkadot
VS_CURRENCY=usd

# Mock mode (set to "true" to skip real API calls)
USE_MOCK_DATA=false

# Spark (only needed for spark-streaming and ml-train services)
SPARK_MASTER=local[*]
SPARK_CHECKPOINT_DIR=/tmp/spark-checkpoints

# MinIO / Storage (mocked S3 for local)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
BRONZE_BUCKET=crypto-bronze
SILVER_BUCKET=crypto-silver
GOLD_BUCKET=crypto-gold

# ML
ML_MODEL_PATH=/tmp/crypto-model
PREDICTION_HORIZON=5

# WebSocket gateway
WS_HOST=0.0.0.0
WS_PORT=8765
WS_GATEWAY_HOST=localhost

# App
APP_PORT=8501

# Telegram alerts (optional — set both to enable)
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id
